{
  "manifest_version": 3,
  "name": "Meeting Pet",
  "version": "1.0.0",
  "description": "A collaborative meeting companion that rewards great cross-team communication",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["reveal.html", "settings.html", "feeding.html", "profile.html", "listen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
